return {
	new = function ()
		const instance = {
			list = nil
		}
		-- could inline functions in table, but want to show off method sugar
		function instance:add(val)
			if self.list == nil then
				self.list = {val = val}
			else
				let curr = self.list
				while curr.next != nil do
					curr = curr.next
				end
				curr.next = {val = val}
			end
		end
		function instance:get(index)
			let curr = self.list
			while index > 0 do
				index = index - 1
				curr = curr.next
			end
			return curr.val
		end
		function instance:remove(index)
			if index == 0 then
				const v = self.list.val
				self.list = self.list.next
				return v
			else
				index = index - 1
				let curr = self.list.next
				let last = self.list
				while index > 0 do
					index = index - 1
					last = curr
					curr = curr.next
				end
				const v = curr.val
				last.next = curr.next
				curr.next = nil
				return v
			end
		end
		function instance:size()
			let curr = self.list
			let size = 0
			while curr != nil do
				size = size + 1
				curr = curr.next
			end
			return size
		end
		return instance
	end
}
