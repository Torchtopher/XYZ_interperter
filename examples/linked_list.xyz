let mylinkedlist = nil
-- linked list nodes are of the form {val = <any>, next = <nil | linked list node>}
function add(val)
	if mylinkedlist == nil then
		mylinkedlist = {val = val}
	else
		let curr = mylinkedlist
		while curr.next != nil do
			curr = curr.next
		end
		curr.next = {val = val}
	end
end

function get(index)
	let curr = mylinkedlist
	while index > 0 do
		index = index - 1
		curr = curr.next
	end
	return curr.val
end

add(1)
io.print(mylinkedlist)
add(2)
io.print(mylinkedlist)
add(3)
io.print(mylinkedlist)
return get(2)
