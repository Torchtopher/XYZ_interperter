return {
	new = function ()
		const instance = {
			list = nil
		}
		-- could inline functions in table, but want to show off method sugar
		function instance:add(val)
			if self.list == nil then
				self.list = {val = val}
			else
				let curr = self.list
				while curr.next != nil do
					curr = curr.next
				end
				curr.next = {val = val}
			end
		end
		function instance:get(index)
			let curr = self.list
			while index > 0 do
				index = index - 1
				curr = curr.next
			end
			return curr.val
		end
		return instance
	end
}
