function fib(n)
	const sequence = {}
	for i = 0,n,1 do
		if i < 2 then
			sequence[i] = 1
		else
			sequence[i] = sequence[i-1] + sequence[i-2]
		end
	end
	return sequence
end
function pretty_print_list(l)
	io.print("{")
	for i = 0,#l,1 do
		io.print("\t" .. l[i] .. ",")
	end
	io.print("}")
end

pretty_print_list(fib(10))
